        "icon": "$(refresh)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.generateLaunchJson",
        "title": "Generate AL Launch Configuration",
        "icon": "$(file-code)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.openWebClient",
        "title": "Open Web Client",
        "icon": "$(globe)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.openTerminal",
        "title": "Open Container Terminal",
        "icon": "$(terminal)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.viewLogs",
        "title": "View Container Logs",
        "icon": "$(output)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.updateHosts",
        "title": "Update Hosts File",
        "icon": "$(globe)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.installCert",
