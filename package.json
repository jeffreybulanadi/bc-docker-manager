{
  "name": "bc-docker-manager",
  "displayName": "BC Docker Manager",
  "description": "Manage Business Central Docker containers from VS Code - browse artifacts, create containers, develop AL apps, and configure your environment without BcContainerHelper or Docker Desktop.",
  "version": "1.5.0",
  "icon": "resources/icon.png",
  "publisher": "jeffreybulanadi",
  "author": {
    "name": "Jeffrey Bulanadi"
  },
  "license": "MIT",
  "galleryBanner": {
    "color": "#0e1726",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffreybulanadi/bc-docker-manager.git"
  },
  "bugs": {
    "url": "https://github.com/jeffreybulanadi/bc-docker-manager/issues"
  },
  "homepage": "https://github.com/jeffreybulanadi/bc-docker-manager#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Testing"
  ],
  "keywords": [
    "business central",
    "docker",
    "dynamics 365",
    "al language",
    "container"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bcDockerManager",
          "title": "BC Docker Manager",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "bcDockerManager": [
        {
          "id": "bcDockerManager-environment",
          "name": "Environment",
          "icon": "$(pulse)"
        },
        {
          "id": "bcDockerManager-containers",
          "name": "Containers",
          "icon": "$(server)"
        },
        {
          "id": "bcDockerManager-artifacts",
          "name": "BC Artifacts",
          "icon": "$(globe)",
          "visibility": "visible"
        },
        {
          "id": "bcDockerManager-images",
          "name": "Local Images",
          "icon": "$(package)"
        },
        {
          "id": "bcDockerManager-volumes",
          "name": "Volumes",
          "icon": "$(database)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "bcDockerManager-containers",
        "contents": "Docker is not available.\nCheck the Environment panel to get started.",
        "when": "bcDockerManager.dockerReady == false"
      },
      {
        "view": "bcDockerManager-containers",
        "contents": "No containers found.\n[Browse Artifacts to Create One](command:bcDockerManager.openExplorer)",
        "when": "bcDockerManager.dockerReady"
      },
      {
        "view": "bcDockerManager-images",
        "contents": "No local images found.\nPull an image from the Artifacts Explorer.",
        "when": "bcDockerManager.dockerReady"
      },
      {
        "view": "bcDockerManager-volumes",
        "contents": "No volumes found.\n[Create Volume](command:bcDockerManager.createVolume)",
        "when": "bcDockerManager.dockerReady"
      },
      {
        "view": "bcDockerManager-artifacts",
        "contents": "Browse and download Business Central artifacts from Microsoft's CDN.\n\n[Open BC Artifacts Explorer](command:bcDockerManager.openExplorer)"
      }
    ],
    "configuration": {
      "title": "BC Docker Manager",
      "properties": {
        "bcDockerManager.defaultMemory": {
          "type": "string",
          "default": "8G",
          "pattern": "^[0-9]+(\\.[0-9]+)?[bBkKmMgG]$",
          "patternErrorMessage": "Memory must include a unit suffix, e.g. 4G, 8G, 512M.",
          "description": "Default memory limit for new containers (e.g. 4G, 8G, 16G)."
        },
        "bcDockerManager.defaultIsolation": {
          "type": "string",
          "default": "hyperv",
          "enum": [
            "hyperv",
            "process"
          ],
          "description": "Default isolation mode for new containers."
        },
        "bcDockerManager.defaultAuth": {
          "type": "string",
          "default": "UserPassword",
          "enum": [
            "UserPassword",
            "NavUserPassword",
            "Windows"
          ],
          "description": "Default authentication type for new containers."
        },
        "bcDockerManager.defaultCountry": {
          "type": "string",
          "default": "us",
          "description": "Default country/locale for artifact browsing (e.g. us, w1, de, fr)."
        },
        "bcDockerManager.defaultDns": {
          "type": "string",
          "default": "8.8.8.8",
          "description": "Default DNS server for containers."
        },
        "bcDockerManager.defaultArtifactType": {
          "type": "string",
          "default": "sandbox",
          "enum": [
            "sandbox",
            "onprem"
          ],
          "description": "Default artifact type when browsing."
        },
        "bcDockerManager.showReleaseNotesOnUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Show the What's New panel automatically when a new version of BC Docker Manager is installed."
        }
      }
    },
    "commands": [
      {
        "command": "bcDockerManager.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.refreshRegistry",
        "title": "Refresh Registry",
        "icon": "$(refresh)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.startContainer",
        "title": "Start Container",
        "icon": "$(play)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.stopContainer",
        "title": "Stop Container",
        "icon": "$(debug-stop)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.restartContainer",
        "title": "Restart Container",
        "icon": "$(debug-restart)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.removeContainer",
        "title": "Remove Container",
        "icon": "$(trash)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.removeImage",
        "title": "Remove Image",
        "icon": "$(trash)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.pullBcImage",
        "title": "Pre-Pull BC Image",
        "icon": "$(cloud-download)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.toggleBcFilter",
        "title": "Toggle BC Filter",
        "icon": "$(filter)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.openExplorer",
        "title": "Open BC Artifacts Explorer",
        "icon": "$(globe)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.testCdn",
        "title": "Test BC Artifacts CDN Connection",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.startDockerEngine",
        "title": "Start Docker Engine",
        "icon": "$(play)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.enableWindowsFeatures",
        "title": "Enable Hyper-V & Windows Containers",
        "icon": "$(gear)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.setupAll",
        "title": "Setup Everything",
        "icon": "$(rocket)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.installDockerEngine",
        "title": "Install Docker Engine",
        "icon": "$(cloud-download)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.refreshEnvironment",
