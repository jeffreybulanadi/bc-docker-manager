      },
      {
        "command": "bcDockerManager.removeVolume",
        "title": "Remove Volume",
        "icon": "$(trash)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.inspectVolume",
        "title": "Inspect Volume",
        "icon": "$(search)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.refreshVolumes",
        "title": "Refresh Volumes",
        "icon": "$(refresh)",
        "category": "BC Docker Manager"
      },
      {
        "command": "bcDockerManager.bulkStartContainers",
        "title": "Start All Stopped Containers",
