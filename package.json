    "menus": {
      "view/title": [
        {
          "command": "bcDockerManager.refreshEnvironment",
          "when": "view == bcDockerManager-environment",
          "group": "navigation@1"
        },
        {
          "command": "bcDockerManager.setupAll",
          "when": "view == bcDockerManager-environment && !bcDockerManager.dockerReady",
          "group": "navigation@2"
        },
        {
          "command": "bcDockerManager.refresh",
          "when": "view == bcDockerManager-containers || view == bcDockerManager-images",
          "group": "navigation@1"
        },
        {
          "command": "bcDockerManager.toggleBcFilter",
          "when": "view == bcDockerManager-containers",
          "group": "navigation@2"
        },
        {
          "command": "bcDockerManager.openExplorer",
          "when": "view == bcDockerManager-containers",
          "group": "navigation@3"
        },
        {
          "command": "bcDockerManager.pullBcImage",
          "when": "view == bcDockerManager-images",
          "group": "navigation@2"
        },
        {
          "command": "bcDockerManager.refreshVolumes",
          "when": "view == bcDockerManager-volumes",
          "group": "navigation@1"
        },
        {
          "command": "bcDockerManager.createVolume",
          "when": "view == bcDockerManager-volumes",
          "group": "navigation@2"
        },
        {
          "command": "bcDockerManager.openExplorer",
          "when": "view == bcDockerManager-artifacts",
          "group": "navigation@1"
        },
        {
          "command": "bcDockerManager.refreshRegistry",
          "when": "view == bcDockerManager-artifacts",
          "group": "navigation@2"
        },
        {
          "command": "bcDockerManager.bulkStopContainers",
          "when": "view == bcDockerManager-containers",
          "group": "bulk@1"
        },
        {
          "command": "bcDockerManager.bulkRemoveContainers",
          "when": "view == bcDockerManager-containers",
          "group": "bulk@2"
        },
        {
          "command": "bcDockerManager.importContainer",
          "when": "view == bcDockerManager-containers || view == bcDockerManager-images",
          "group": "bulk@3"
        },
        {
          "command": "bcDockerManager.saveProfile",
          "when": "view == bcDockerManager-containers",
          "group": "bulk@4"
        },
        {
          "command": "bcDockerManager.loadProfile",
          "when": "view == bcDockerManager-containers",
          "group": "bulk@5"
        },
        {
          "command": "bcDockerManager.editProfile",
          "when": "view == bcDockerManager-containers",
          "group": "bulk@6"
        },
        {
          "command": "bcDockerManager.deleteProfile",
          "when": "view == bcDockerManager-containers",
          "group": "bulk@7"
        }
      ],
      "view/item/context": [
        {
          "command": "bcDockerManager.startContainer",
          "when": "view == bcDockerManager-containers && viewItem == stoppedContainer",
          "group": "inline@1"
        },
        {
          "command": "bcDockerManager.stopContainer",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "inline@1"
        },
        {
          "command": "bcDockerManager.restartContainer",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "inline@2"
        },
        {
          "command": "bcDockerManager.removeContainer",
          "when": "view == bcDockerManager-containers && (viewItem == stoppedContainer || viewItem == runningContainer)",
          "group": "inline@3"
        },
        {
          "command": "bcDockerManager.openWebClient",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "inline@4"
        },
        {
          "command": "bcDockerManager.setupNetworking",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "inline@5"
        },
        {
          "command": "bcDockerManager.startContainer",
          "when": "view == bcDockerManager-containers && viewItem == stoppedContainer",
          "group": "container@1"
        },
        {
          "command": "bcDockerManager.stopContainer",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "container@1"
        },
        {
          "command": "bcDockerManager.restartContainer",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "container@2"
        },
        {
          "command": "bcDockerManager.removeContainer",
          "when": "view == bcDockerManager-containers && (viewItem == stoppedContainer || viewItem == runningContainer)",
          "group": "container@3"
        },
        {
          "command": "bcDockerManager.removeImage",
          "when": "view == bcDockerManager-images && viewItem == image",
          "group": "inline@1"
        },
        {
          "command": "bcDockerManager.removeImage",
          "when": "view == bcDockerManager-images && viewItem == image",
          "group": "image@1"
        },
        {
          "command": "bcDockerManager.generateLaunchJson",
          "when": "view == bcDockerManager-containers && (viewItem == stoppedContainer || viewItem == runningContainer)",
          "group": "connect@1"
        },
        {
          "command": "bcDockerManager.openWebClient",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "connect@2"
        },
        {
          "command": "bcDockerManager.openTerminal",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "connect@3"
        },
        {
          "command": "bcDockerManager.viewLogs",
          "when": "view == bcDockerManager-containers && (viewItem == stoppedContainer || viewItem == runningContainer)",
          "group": "connect@4"
        },
        {
          "command": "bcDockerManager.setupNetworking",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "connect@5"
        },
        {
          "command": "bcDockerManager.updateHosts",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "connect@6"
        },
        {
          "command": "bcDockerManager.installCert",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "connect@7"
        },
        {
          "command": "bcDockerManager.copyLaunchJson",
          "when": "view == bcDockerManager-containers && (viewItem == stoppedContainer || viewItem == runningContainer)",
          "group": "connect@8"
        },
        {
          "command": "bcDockerManager.previewLaunchJson",
          "when": "view == bcDockerManager-containers && (viewItem == stoppedContainer || viewItem == runningContainer)",
          "group": "connect@9"
        },
        {
          "command": "bcDockerManager.installDockerEngine",
          "when": "view == bcDockerManager-environment && viewItem == health_docker_error",
          "group": "inline@1"
        },
        {
          "command": "bcDockerManager.startDockerEngine",
          "when": "view == bcDockerManager-environment && viewItem == health_docker_warn",
          "group": "inline@1"
        },
        {
          "command": "bcDockerManager.enableWindowsFeatures",
          "when": "view == bcDockerManager-environment && viewItem =~ /health_features_(error|warn)/",
          "group": "inline@1"
        },
        {
          "command": "bcDockerManager.copyContainerIp",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "connect@10"
        },
        {
          "command": "bcDockerManager.publishApp",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "bcops@1"
        },
        {
          "command": "bcDockerManager.uploadLicense",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "bcops@2"
        },
        {
          "command": "bcDockerManager.addUser",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "bcops@3"
        },
        {
          "command": "bcDockerManager.addTestUsers",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "bcops@4"
        },
        {
          "command": "bcDockerManager.backupDatabase",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "bcdata@1"
        },
        {
          "command": "bcDockerManager.restoreDatabase",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "bcdata@2"
        },
        {
          "command": "bcDockerManager.installTestToolkit",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "bcdata@3"
        },
        {
          "command": "bcDockerManager.showStats",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "bcpro@1"
        },
        {
          "command": "bcDockerManager.editNstSettings",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "bcpro@2"
        },
        {
          "command": "bcDockerManager.viewEventLog",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "bcpro@3"
        },
        {
          "command": "bcDockerManager.compileApp",
          "when": "view == bcDockerManager-containers && viewItem == runningContainer",
          "group": "bcpro@4"
        },
        {
          "command": "bcDockerManager.exportContainer",
          "when": "view == bcDockerManager-containers && (viewItem == stoppedContainer || viewItem == runningContainer)",
          "group": "bcadvanced@1"
        },
        {
          "command": "bcDockerManager.setContainerNote",
          "when": "view == bcDockerManager-containers && (viewItem == stoppedContainer || viewItem == runningContainer)",
          "group": "notes@1"
        },
        {
          "command": "bcDockerManager.setContainerTags",
          "when": "view == bcDockerManager-containers && (viewItem == stoppedContainer || viewItem == runningContainer)",
          "group": "notes@2"
        },
        {
          "command": "bcDockerManager.clearContainerAnnotations",
          "when": "view == bcDockerManager-containers && (viewItem == stoppedContainer || viewItem == runningContainer)",
          "group": "notes@3"
        },
        {
          "command": "bcDockerManager.removeVolume",
          "when": "view == bcDockerManager-volumes && viewItem == volume",
          "group": "inline@1"
        },
        {
          "command": "bcDockerManager.inspectVolume",
          "when": "view == bcDockerManager-volumes && viewItem == volume",
          "group": "volume@1"
        },
        {
          "command": "bcDockerManager.removeVolume",
          "when": "view == bcDockerManager-volumes && viewItem == volume",
          "group": "volume@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\" && node esbuild.js --production",
    "compile": "tsc -p ./",
    "esbuild": "node esbuild.js",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "test": "jest",
    "pretest:e2e": "npm run compile",
    "test:e2e": "tsc -p e2e/tsconfig.json && node out/e2e/runTests.js",
    "pretest:ui": "npm run compile && tsc -p ui-tests/tsconfig.json",
    "test:ui": "node out/ui-tests/runTests.js",
    "prescreenshots": "npm run compile && tsc -p screenshots/tsconfig.json",
    "screenshots": "node out/screenshots/capture.js"
  },
